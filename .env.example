# ─────────────────────────────────────────────────────────────────────────────
# trader-cockpit-app — environment configuration
# Copy this file to .env and fill in the values.
# Lines starting with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────────────────────
DB_USER=trader
DB_PASSWORD=trader_secret
DB_NAME=trader_cockpit

# ── Redis ──────────────────────────────────────────────────────────────────────
# Both services read REDIS_URL directly from the environment.
REDIS_URL=redis://redis:6379

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Dhan API (required for 1-minute historical data) ──────────────────────────
# Obtain from: https://dhanhq.co -> My Account -> API Access
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ── DataSyncService tuning (optional overrides) ────────────────────────────────
# DB_POOL_MIN_SIZE=5
# DB_POOL_MAX_SIZE=20
# DB_COMMAND_TIMEOUT=60
# DHAN_MAX_CONCURRENCY=5
# DHAN_MASTER_TTL_HOURS=24
# SYNC_BATCH_SIZE=50
# SYNC_BATCH_DELAY_S=1.5
# SYNC_1D_HISTORY_DAYS=1825
# SYNC_1M_HISTORY_DAYS=90

# ── MomentumScorerService tuning (optional overrides) ─────────────────────────
# SCORE_LOOKBACK_BARS=200
# SCORE_MIN_BARS=30
# SCORE_CONCURRENCY=10
# RSI_PERIOD=14
# MACD_FAST=12
# MACD_SLOW=26
# MACD_SIGNAL=9
# ROC_PERIOD=10
# VOL_AVG_PERIOD=20
# WEIGHT_RSI=0.30
# WEIGHT_MACD=0.30
# WEIGHT_ROC=0.25
# WEIGHT_VOL=0.15

# ── Docker data volumes ────────────────────────────────────────────────────────
# Host path for persistent TimescaleDB and Redis data.
# Use forward slashes even on Windows (Docker Desktop translates them).
DOCKER_DATA_PATH=d:/docker-data
