# ─────────────────────────────────────────────────────────────────────────────
# trader-cockpit-app — environment configuration
# Copy this file to .env and fill in the values.
# Lines starting with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database — app credentials ────────────────────────────────────────────────
DB_USER=trader
DB_PASSWORD=trader_secret
DB_NAME=trader_cockpit

# ── External PostgreSQL / TimescaleDB host ───────────────────────────────────
# `host.docker.internal` works on Docker Desktop. Override if your DB runs on
# another host reachable from the containers.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432

# ── External PostgreSQL superuser (used by db-init to bootstrap the DB) ──────
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=

# ── Redis ──────────────────────────────────────────────────────────────────────
# Both services read REDIS_URL directly from the environment.
REDIS_URL=redis://redis:6379

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Dhan API credentials (required for LiveFeedService + DataSyncService) ────────
# Get these from Dhan developer portal: https://dhanhq.co/docs/v2/
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ── DataSyncService tuning (optional overrides) ────────────────────────────────
# DB_POOL_MIN_SIZE=5
# DB_POOL_MAX_SIZE=20
# DB_COMMAND_TIMEOUT=60
# SYNC_BATCH_SIZE=50
# SYNC_BATCH_DELAY_S=1.5
# SYNC_1D_HISTORY_DAYS=1825

# ── MomentumScorerService tuning (optional overrides) ─────────────────────────
# SCORE_LOOKBACK_BARS=200
# SCORE_MIN_BARS=30
# SCORE_CONCURRENCY=10
# RSI_PERIOD=14
# MACD_FAST=12
# MACD_SLOW=26
# MACD_SIGNAL=9
# ROC_PERIOD=10
# VOL_AVG_PERIOD=20
# WEIGHT_RSI=0.30
# WEIGHT_MACD=0.30
# WEIGHT_ROC=0.25
# WEIGHT_VOL=0.15

# ── LiveFeedService tuning (optional overrides) ───────────────────────────────
# DHAN_WS_BATCH_SIZE=500          # instruments per WebSocket connection (500 = 5 connections for up to 2500 instruments)
# DHAN_RECONNECT_DELAY_S=5.0      # seconds before reconnecting after a drop
# CANDLE_WRITE_BATCH_SIZE=100     # candles buffered before a DB flush
# CANDLE_WRITE_FLUSH_S=5.0        # max seconds between DB flushes
# DRIVE_CANDLES=5                  # candles evaluated for open drive
# DRIVE_CONFIRMED_THRESH=0.70      # confidence >= this → CONFIRMED drive
# SPIKE_WINDOW=20                  # rolling window for volume/price baselines
# SPIKE_VOL_RATIO=3.0              # vol / avg_vol >= this → spike
# SPIKE_PRICE_PCT=1.5              # % price move >= this → shock

# ── Docker data volumes ────────────────────────────────────────────────────────
# Host path for persistent Redis container data.
# Use forward slashes even on Windows (Docker Desktop translates them).
DOCKER_DATA_PATH=d:/docker-data
