# Copy this file to .env and fill in real values.
# .env is git-ignored; never commit credentials.

# PostgreSQL
POSTGRES_PASSWORD=changeme

# Dhan API — from https://login.dhan.co → My Profile → API Access
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Optional — override API concurrency / rate-limit settings
# DHAN_MAX_CONCURRENCY=5
# DHAN_DELAY_MS=120
